BROU_API_RETRIES=3

# ===========================================
# MONITORING & LOGGING
# ===========================================

# Enable security audit logging
AUDIT_LOGGING_ENABLED=true

# Log file path
LOG_FILE=sifu.log

# Maximum log file size (MB)
MAX_LOG_SIZE=100

# Log backup count
LOG_BACKUP_COUNT=5
