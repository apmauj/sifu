# SIFU Production Test Environment Configuration
# ⚠️  WARNING: For TESTING ONLY - NOT for production use
# This file uses SQLite for easy testing, but production should use PostgreSQL

# ===========================================
# REQUIRED SECRETS (Test values - CHANGE in production)
# ===========================================

# Database connection string - SQLite for testing (CHANGE to PostgreSQL in production)
DATABASE_URL=sqlite:///./data/sifu_production_test.db

# Secret key for session management (min 32 chars) - TEST VALUE
SECRET_KEY=TEST_PRODUCTION_SECRET_KEY_64_CHARS_MINIMUM_FOR_SECURITY_TESTING_ONLY

# API key for external services (min 20 chars) - TEST VALUE
API_KEY=TEST_PRODUCTION_API_KEY_32_CHARS_MINIMUM_FOR_SECURITY_TESTING

# ===========================================
# OPTIONAL SECRETS (Test values - CHANGE in production)
# ===========================================

# Encryption key for sensitive data (32 chars) - TEST VALUE
ENCRYPTION_KEY=TEST_ENCRYPTION_KEY_32_CHARS_FOR_TESTING_PURPOSES_ONLY

# JWT secret for token authentication (if implemented) - TEST VALUE
JWT_SECRET=TEST_JWT_SECRET_64_CHARS_FOR_TESTING_SECURITY_IMPLEMENTATION

# Redis URL for caching (required for production performance) - TEST VALUE
REDIS_URL=redis://localhost:6379

# Log encryption key (CRITICAL for production log security) - TEST VALUE
LOG_ENCRYPTION_KEY=TEST_LOG_ENCRYPTION_KEY_32_CHARS_FOR_SECURITY_AUDIT

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Environment (MUST be production for testing production config)
ENVIRONMENT=production

# Server configuration
HOST=0.0.0.0
PORT=8000
BACKEND_PORT=8000
RELOAD=false

# Debug mode (MUST be disabled in production)
DEBUG=false

# Logging level (WARNING/ERROR for production)
LOG_LEVEL=WARNING

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# CORS allowed origins (ONLY your production domains)
# Format: https://yourdomain.com,https://www.yourdomain.com
ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Rate limiting (MUST be enabled in production)
DISABLE_RATE_LIMITING=false

# ===========================================
# SCHEDULER CONFIGURATION
# ===========================================

# Background scheduler (enable for production)
SIFU_SCHEDULER_ENABLED=true
SCHEDULER_ENABLED=true

# Timezone for scheduler
TIMEZONE=America/Montevideo
SCHEDULER_TIMEZONE=America/Montevideo

# Cron expressions for data refresh (adjust for production load)
CRON_UI_REFRESH=0 2 * * *
UI_REFRESH_CRON=0 2 * * *
CRON_EXCHANGE_REFRESH=0 3 * * *
EXCHANGE_REFRESH_CRON=0 3 * * *
CRON_UR_REFRESH=0 4 1 * *
UR_REFRESH_CRON=0 4 1 * *

# ===========================================
# EXTERNAL API CONFIGURATION
# ===========================================

# BCU API settings (increase timeouts for production)
BCU_API_TIMEOUT=60
BCU_API_RETRIES=5

# BROU API settings (increase timeouts for production)
BROU_API_TIMEOUT=60
BROU_API_RETRIES=5

# ===========================================
# MONITORING & LOGGING
# ===========================================

# Security audit logging (CRITICAL for production)
AUDIT_LOGGING_ENABLED=true

# Log file path (use absolute path in production)
LOG_FILE=./logs/sifu_production.log

# Maximum log file size (MB) - larger for production
MAX_LOG_SIZE=500

# Log backup count - more backups for production
LOG_BACKUP_COUNT=10

# ===========================================
# PRODUCTION-SPECIFIC SETTINGS
# ===========================================

# SSL/TLS (enable in production) - DISABLED for testing
SSL_CERT_PATH=
SSL_KEY_PATH=

# Database connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

# Cache settings
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# ===========================================
# BACKUP & RECOVERY
# ===========================================

# Backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ===========================================
# ALERTING & NOTIFICATIONS
# ===========================================

# Alert endpoints - DISABLED for testing
ALERT_WEBHOOK_URL=
ALERT_EMAIL=

# Alert thresholds
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85
ALERT_DISK_THRESHOLD=90
