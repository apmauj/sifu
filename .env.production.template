# SIFU Production Environment Configuration Template
# ⚠️  WARNING: This template contains SECURE DEFAULTS for PRODUCTION
# Copy this file to .env and MODIFY all values before deploying
# Generated on: 2025-08-29

# ===========================================
# REQUIRED SECRETS (Must be configured)
# ===========================================

# Database connection string - USE EXTERNAL MANAGED DB IN PRODUCTION
# Format: postgresql://user:password@host:port/database
# NEVER use sqlite:/// in production
DATABASE_URL=postgresql://sifu_user:CHANGE_THIS_STRONG_PASSWORD@your-db-host:5432/sifu_prod

# Secret key for session management (min 32 chars) - GENERATE NEW ONE
SECRET_KEY=CHANGE_THIS_TO_A_NEW_64_CHAR_RANDOM_SECRET_KEY_FOR_PRODUCTION

# API key for external services (min 20 chars) - USE SECURE VAULT
API_KEY=CHANGE_THIS_TO_A_NEW_SECURE_API_KEY_FROM_VAULT

# ===========================================
# OPTIONAL SECRETS (Required for production)
# ===========================================

# Encryption key for sensitive data (32 chars) - STORE IN VAULT
ENCRYPTION_KEY=CHANGE_THIS_TO_A_NEW_32_CHAR_ENCRYPTION_KEY

# JWT secret for token authentication (if implemented)
JWT_SECRET=CHANGE_THIS_TO_A_NEW_64_CHAR_JWT_SECRET

# Redis URL for caching (required for production performance)
REDIS_URL=redis://your-redis-host:6379

# Log encryption key (CRITICAL for production log security)
LOG_ENCRYPTION_KEY=CHANGE_THIS_TO_A_NEW_32_CHAR_LOG_ENCRYPTION_KEY

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Environment (MUST be production)
ENVIRONMENT=production

# Server configuration
HOST=0.0.0.0
PORT=8000
BACKEND_PORT=8000
RELOAD=false

# Debug mode (MUST be disabled in production)
DEBUG=false

# Logging level (WARNING/ERROR for production)
LOG_LEVEL=WARNING

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# CORS allowed origins (ONLY your production domains)
# Format: https://yourdomain.com,https://www.yourdomain.com
ALLOW_ORIGINS=https://your-sifu-domain.com,https://www.your-sifu-domain.com

# Rate limiting (MUST be enabled in production)
DISABLE_RATE_LIMITING=false

# ===========================================
# SCHEDULER CONFIGURATION
# ===========================================

# Background scheduler (enable for production)
SIFU_SCHEDULER_ENABLED=true
SCHEDULER_ENABLED=true

# Timezone for scheduler
TIMEZONE=America/Montevideo
SCHEDULER_TIMEZONE=America/Montevideo

# Cron expressions for data refresh (adjust for production load)
CRON_UI_REFRESH=0 2 * * *
UI_REFRESH_CRON=0 2 * * *
CRON_EXCHANGE_REFRESH=0 3 * * *
EXCHANGE_REFRESH_CRON=0 3 * * *
CRON_UR_REFRESH=0 4 1 * *
UR_REFRESH_CRON=0 4 1 * *

# ===========================================
# EXTERNAL API CONFIGURATION
# ===========================================

# BCU API settings (increase timeouts for production)
BCU_API_TIMEOUT=60
BCU_API_RETRIES=5

# BROU API settings (increase timeouts for production)
BROU_API_TIMEOUT=60
BROU_API_RETRIES=5

# ===========================================
# MONITORING & LOGGING
# ===========================================

# Security audit logging (CRITICAL for production)
AUDIT_LOGGING_ENABLED=true

# Log file path (use absolute path in production)
LOG_FILE=/var/log/sifu/sifu.log

# Maximum log file size (MB) - larger for production
MAX_LOG_SIZE=500

# Log backup count - more backups for production
LOG_BACKUP_COUNT=10

# ===========================================
# PRODUCTION-SPECIFIC SETTINGS
# ===========================================

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=false

# SSL/TLS (enable in production)
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/private.key

# Database connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

# Cache settings
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# ===========================================
# BACKUP & RECOVERY
# ===========================================

# Backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ===========================================
# ALERTING & NOTIFICATIONS
# ===========================================

# Alert endpoints
ALERT_WEBHOOK_URL=https://your-alert-system.com/webhook
ALERT_EMAIL=alerts@yourdomain.com

# Alert thresholds
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85
ALERT_DISK_THRESHOLD=90
