# Example environment configuration for SIFU
# Copy to `.env` (docker-compose) o exportar en tu entorno antes de ejecutar.
# Ninguna de estas variables contiene secretos; ajusta según despliegue.

############################################
# Timezone
############################################
# Zona horaria usada por APScheduler (cron) y ventanas horarias.
TIMEZONE=America/Montevideo

############################################
# Scheduler toggles
############################################
# Habilita/deshabilita completamente el scheduler de fondo
SIFU_SCHEDULER_ENABLED=true
# Ejecutar sólo días hábiles (lunes-viernes y no feriados listados)
SCHEDULER_BUSINESS_DAY_ONLY=true
# Feriados (ISO YYYY-MM-DD) separados por coma
SCHEDULER_HOLIDAYS=2025-01-01,2025-05-01

############################################
# Daily refresh crons (formato estándar: m h dom mes dow)
############################################
# UI: 02:00 local
CRON_UI_REFRESH=0 2 * * *
# Exchange histórico: 03:00 local
CRON_EXCHANGE_REFRESH=0 3 * * *
# UR mensual día 1 a las 04:00 local
CRON_UR_REFRESH=0 4 1 * *

############################################
# Hourly exchange freshness check
############################################
# Cron horario (por defecto cada hora al minuto 0)
CRON_EXCHANGE_HOURLY_CHECK=0 * * * *
# Habilitar chequeo horario
EXCHANGE_HOURLY_CHECK_ENABLED=true
# Ventana horaria (inclusive) en hora local para intentar refrescar si falta el día actual
EXCHANGE_HOURLY_CHECK_START_HOUR=9
EXCHANGE_HOURLY_CHECK_END_HOUR=18

############################################
# Optional bootstrap / test flags
############################################
# Omitir bootstrap pesado (descargas iniciales) al iniciar (útil tests)
SIFU_SKIP_BOOTSTRAP=0
# Omitir refresh inicial si la DB está vacía (legacy path)
SIFU_SKIP_STARTUP_REFRESH=0

############################################
# CORS (en producción definir orígenes permitidos explícitamente)
############################################
# Coma-separado; usar * sólo en entornos de desarrollo sin credenciales
ALLOW_ORIGINS=*

############################################
# Database
############################################
# Ruta/URL SQLite por defecto; para Postgres usar DATABASE_URL
DATABASE_PATH=./ui_data.db
# DATABASE_URL=postgresql://user:pass@host:5432/sifu

############################################
# Frontend/Backend misc
############################################
# Ajustar si quieres limitar logs
LOG_LEVEL=INFO

# Fin del archivo
